{
  "name": "cursor-daily-budget",
  "displayName": "Cursor Daily Budget",
  "description": "自动追踪 Cursor API 用量、工作日每日预算与今日 API 消耗",
  "version": "0.6.2",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Cursor Daily Budget",
      "properties": {
        "cursorBudget.refreshIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "状态栏自动刷新间隔（秒）"
        },
        "cursorBudget.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "是否在状态栏显示预算信息"
        },
        "cursorBudget.warningThresholdPercent": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "API 用量超过此百分比时状态栏显示警告图标"
        },
        "cursorBudget.criticalThresholdPercent": {
          "type": "number",
          "default": 95,
          "minimum": 0,
          "maximum": 100,
          "description": "API 用量超过此百分比时状态栏显示严重警告图标"
        }
      }
    },
    "commands": [
      {
        "command": "cursorBudget.refresh",
        "title": "Cursor Budget: Refresh"
      },
      {
        "command": "cursorBudget.openDashboard",
        "title": "Cursor Budget: Open Dashboard"
      },
      {
        "command": "cursorBudget.quickMenu",
        "title": "Cursor Budget: Menu"
      }
    ]
  }
}
